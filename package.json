{
  "name": "react-xray",
  "version": "0.0.1",
  "description": "Per-page component reachability for React apps",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "react-xray": "./bin/react-xray"
  },
  "files": ["dist", "bin", "README.md", "LICENSE"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "cac": "^6.7.14",
    "globby": "^14.0.0",
    "oxc-parser": "^0.133.0",
    "oxc-resolver": "^11.19.1",
    "picocolors": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "keywords": ["react", "nextjs", "analyzer", "unused", "components", "dead-code", "static-analysis"],
  "license": "MIT"
}
